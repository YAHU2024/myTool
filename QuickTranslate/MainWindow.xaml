<Window x:Class="QuickTranslate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuickTranslate"
        mc:Ignorable="d"
        Title="QuickTranslate - 划词翻译" Height="500" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    <Window.Resources>
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#555577"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部：目标语言选择 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="目标语言：" Foreground="#A0A0C0" FontSize="14" 
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="LanguageComboBox" Width="160" Height="32"
                      FontSize="13" VerticalContentAlignment="Center"
                      Background="#2D2D3F" Foreground="#E0E0E0"
                      SelectionChanged="LanguageComboBox_SelectionChanged"/>
        </StackPanel>

        <!-- 中部：原文 + 译文 左右分栏 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 原文输入区 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="原文" Foreground="#A0A0C0" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="SourceTextBox" Grid.Row="1"
                         Style="{StaticResource DarkTextBox}"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="SourceTextBox_TextChanged"/>
            </Grid>

            <!-- 译文结果区 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="译文" Foreground="#A0A0C0" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="ResultTextBox" Grid.Row="1"
                         Style="{StaticResource DarkTextBox}"
                         TextWrapping="Wrap" IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Grid>

        <!-- 底部：翻译按钮 + 状态 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,12">
            <Button x:Name="TranslateButton" Content="翻 译" 
                    Style="{StaticResource PrimaryButton}"
                    Click="TranslateButton_Click"/>
            <TextBlock x:Name="StatusText" Text="" Foreground="#888899" FontSize="12" 
                       VerticalAlignment="Center" Margin="16,0,0,0"/>
        </StackPanel>

        <!-- 设置区域 -->
        <Border Grid.Row="3" Background="#252537" CornerRadius="8" Padding="12">
            <StackPanel>
                <TextBlock Text="API 设置" Foreground="#A0A0C0" FontSize="12" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Base URL:" Foreground="#888899" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="ApiBaseUrlTextBox" Grid.Row="0" Grid.Column="1" 
                             Style="{StaticResource SettingsTextBox}" Margin="0,0,8,0"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="API Key:" Foreground="#888899" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="ApiKeyTextBox" Grid.Row="0" Grid.Column="3" Width="180"
                             Style="{StaticResource SettingsTextBox}" Margin="0,0,8,0"/>

                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Model:" Foreground="#888899" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="ModelComboBox" Grid.Row="0" Grid.Column="5" Width="200"
                              IsEditable="True" Style="{StaticResource DarkComboBox}"
                              SelectionChanged="ModelComboBox_SelectionChanged"/>

                    <Button Grid.Row="2" Grid.Column="5" Content="保存设置" 
                            Style="{StaticResource PrimaryButton}" FontSize="12" Padding="12,4"
                            Click="SaveSettings_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
