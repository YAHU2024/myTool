<Window x:Class="QuickTranslate.UI.RedDotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RedDot"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        ShowActivated="False">

    <Grid Width="16" Height="16" Cursor="Hand" MouseEnter="Grid_MouseEnter">
        <Ellipse Width="12" Height="12" Fill="#E53935" Stroke="#B71C1C" StrokeThickness="0.5">
            <Ellipse.Effect>
                <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.4"/>
            </Ellipse.Effect>
        </Ellipse>
    </Grid>
</Window>
