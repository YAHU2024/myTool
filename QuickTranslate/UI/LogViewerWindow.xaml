<Window x:Class="QuickTranslate.UI.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="日志查看" Width="980" Height="620"
        Background="#171724" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="LogFileComboBox" Grid.Column="0" Margin="0,0,8,0"
                      SelectionChanged="LogFileComboBox_SelectionChanged"/>
            <ComboBox x:Name="LevelComboBox" Grid.Column="1" Margin="0,0,8,0"
                      SelectionChanged="Filter_Changed"/>
            <TextBox x:Name="SearchTextBox" Grid.Column="2" Margin="0,0,8,0"
                     VerticalContentAlignment="Center" TextChanged="Filter_Changed"/>
            <Button Grid.Column="3" Content="刷新" Padding="12,5" Margin="0,0,8,0" Click="RefreshButton_Click"/>
            <Button Grid.Column="4" Content="打开目录" Padding="12,5" Margin="0,0,8,0" Click="OpenDirectoryButton_Click"/>
            <Button Grid.Column="5" Content="清理" Padding="12,5" Click="CleanupButton_Click"/>
        </Grid>
        <ListView x:Name="EntriesListView" Grid.Row="2" Background="#202032" BorderBrush="#444466"
                  Foreground="#E0E0E0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.View>
                <GridView AllowsColumnReorder="False">
                    <GridViewColumn Header="时间" Width="155" DisplayMemberBinding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss.fff}"/>
                    <GridViewColumn Header="级别" Width="65" DisplayMemberBinding="{Binding Level}"/>
                    <GridViewColumn Header="模块" Width="150" DisplayMemberBinding="{Binding Source}"/>
                    <GridViewColumn Header="事件" Width="520" DisplayMemberBinding="{Binding DisplayText}"/>
                </GridView>
            </ListView.View>
        </ListView>
        <TextBlock x:Name="StatusTextBlock" Grid.Row="4" Foreground="#A0A0C0"/>
    </Grid>
</Window>
