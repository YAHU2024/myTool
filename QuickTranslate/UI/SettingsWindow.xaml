<Window x:Class="QuickTranslate.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="QuickTranslate 设置" Height="620" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#1E1E2E">
    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A0A0C0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#1E1E2E"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="8,4"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="#A0A0C0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3D3D5F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EyeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888899"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Grid Margin="0,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

        <!-- API 配置 -->
        <Border Grid.Row="0" Background="#252537" CornerRadius="8" Padding="16">
            <StackPanel>
                <TextBlock Text="API 配置" Foreground="#E0E0E0" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Base URL:" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="ApiBaseUrlTextBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                             Style="{StaticResource InputTextBox}"
                             LostFocus="Input_LostFocus"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="API Key:" Style="{StaticResource LabelStyle}"/>
                    <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="ApiKeyPasswordBox" Grid.Column="0"
                                     Background="#2D2D3F" Foreground="#E0E0E0"
                                     BorderBrush="#444466" BorderThickness="1"
                                     Padding="8,6" FontSize="13" FontFamily="Microsoft YaHei UI"
                                     CaretBrush="#E0E0E0"
                                     PasswordChar="●"
                                     LostFocus="Input_LostFocus"/>
                        <TextBox x:Name="ApiKeyVisibleTextBox" Grid.Column="0"
                                 Style="{StaticResource InputTextBox}"
                                 Visibility="Collapsed"
                                 LostFocus="Input_LostFocus"/>
                        <Button x:Name="EyeButton" Grid.Column="1" 
                                Style="{StaticResource EyeButton}"
                                Content="👁" ToolTip="显示/隐藏 API Key"
                                Click="EyeButton_Click" Margin="4,0,0,0"/>
                    </Grid>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="模型:" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="ModelComboBox" Grid.Row="4" Grid.Column="1"
                              IsEditable="True" Style="{StaticResource DarkComboBox}"
                              SelectionChanged="ModelComboBox_SelectionChanged"
                              LostFocus="Input_LostFocus"/>
                    <Button x:Name="DeleteConfigButton" Grid.Row="4" Grid.Column="2"
                            Content="删除" Padding="10,4" FontSize="12" Margin="8,0,0,0"
                            IsEnabled="False"
                            Click="DeleteConfigButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#2D2D3F"/>
                                <Setter Property="Foreground" Value="#A0A0C0"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="#444466"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF4444"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#FF4444"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Foreground" Value="#555566"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 模型切换反馈 -->
                    <TextBlock x:Name="ModelFeedbackText" Grid.Row="6" Grid.Column="1"
                               Foreground="#6EE7A0" FontSize="11" Margin="0,2,0,0"
                               Visibility="Collapsed"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 翻译设置 -->
        <Border Grid.Row="2" Background="#252537" CornerRadius="8" Padding="16">
            <StackPanel>
                <TextBlock Text="翻译设置" Foreground="#E0E0E0" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="目标语言:" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="LanguageComboBox" Grid.Row="0" Grid.Column="1" 
                              Style="{StaticResource DarkComboBox}"
                              SelectionChanged="LanguageComboBox_SelectionChanged"/>
                    <TextBox x:Name="CustomLanguageTextBox" Grid.Row="0" Grid.Column="2" 
                             Width="100" Margin="8,0,0,0"
                             Style="{StaticResource InputTextBox}"
                             Visibility="Collapsed"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="翻译开关:" Style="{StaticResource LabelStyle}"/>
                    <CheckBox x:Name="TranslationEnabledCheckBox" Grid.Row="2" Grid.Column="1"
                              Style="{StaticResource DarkCheckBox}"
                              Content="启用划词翻译和热键翻译"
                              Grid.ColumnSpan="2"
                              Checked="Setting_Changed" Unchecked="Setting_Changed"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="语言检测:" Style="{StaticResource LabelStyle}"/>
                    <CheckBox x:Name="AutoDetectLanguageCheckBox" Grid.Row="4" Grid.Column="1"
                              Style="{StaticResource DarkCheckBox}"
                              Content="自动检测语言方向（中文→英文，其他→中文）"
                              Grid.ColumnSpan="2"
                              Checked="Setting_Changed" Unchecked="Setting_Changed"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="自定义提示词:" Style="{StaticResource LabelStyle}" VerticalAlignment="Top" Margin="0,4,12,0"/>
                    <TextBox x:Name="CustomSystemPromptTextBox" Grid.Row="6" Grid.Column="1"
                             Style="{StaticResource InputTextBox}"
                             Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             ToolTip="自定义翻译提示词，留空使用默认。支持 {targetLang} 占位符"
                             Grid.ColumnSpan="2"
                             TextChanged="Input_LostFocus"/>
                    <TextBlock Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2"
                               Text="提示：留空使用默认提示词。支持 {targetLang} 占位符，运行时替换为目标语言。"
                               Foreground="#666688" FontSize="11" Margin="0,2,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 系统设置 -->
        <Border Grid.Row="4" Background="#252537" CornerRadius="8" Padding="16">
            <StackPanel>
                <TextBlock Text="系统设置" Foreground="#E0E0E0" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="开机自启:" Style="{StaticResource LabelStyle}"/>
                    <CheckBox x:Name="AutoStartCheckBox" Grid.Row="0" Grid.Column="1"
                              Style="{StaticResource DarkCheckBox}"
                              Content="开机自动启动"
                              Grid.ColumnSpan="2"
                              Checked="Setting_Changed" Unchecked="Setting_Changed"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="快捷键:" Style="{StaticResource LabelStyle}"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                        <TextBlock x:Name="HotKeyDisplayText" Foreground="#E0E0E0" FontSize="13"
                                   VerticalAlignment="Center" Text="Alt+Q"/>
                        <Button x:Name="ChangeHotKeyButton" Style="{StaticResource SecondaryButton}"
                                Content="修改" Margin="12,0,0,0" Padding="12,6"
                                Click="ChangeHotKeyButton_Click"/>
                        <TextBlock x:Name="HotKeyCaptureHint" Foreground="#FFA500" FontSize="12"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Visibility="Collapsed" Text="请按新的快捷键..."/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取 消" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="保 存" Style="{StaticResource PrimaryButton}"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
