<Window x:Class="QuickTranslate.UI.FloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="QuickTranslate"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        MaxWidth="420">

    <Border Background="#E81E1E2E" CornerRadius="8" Padding="14,10" Margin="4">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <!-- 译文（白色大字，支持点击复制） -->
            <TextBlock x:Name="TranslationTextBlock"
                       Foreground="#F0F0F0"
                       FontSize="16"
                       FontFamily="Microsoft YaHei UI"
                       TextWrapping="Wrap"
                       MaxWidth="390"
                       Cursor="Hand"
                       ToolTip="点击复制译文"
                       MouseLeftButtonDown="TranslationTextBlock_MouseLeftButtonDown"
                       Text=""/>
        </Grid>
    </Border>
</Window>
