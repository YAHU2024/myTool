<Window x:Class="QuickTranslate.UI.FloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickTranslate"
        WindowStyle="None"
        ResizeMode="CanResize"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        AllowsTransparency="True"
        Background="Transparent"
        Width="420"
        MinWidth="400"
        MaxWidth="900"
        MinHeight="120"
        MaxHeight="800"
        SizeToContent="Height"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <Style x:Key="ToolbarButton" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="#D7D7DE"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="Margin" Value="0,0,3,0"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#38384B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#4C4C63"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeButton" TargetType="{x:Type Button}" BasedOn="{StaticResource ToolbarButton}">
            <Style.Triggers>
                <Trigger Property="Tag" Value="ActiveTranslation">
                    <Setter Property="Background" Value="#4488FF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="Tag" Value="ActiveCode">
                    <Setter Property="Background" Value="#FFA500"/>
                    <Setter Property="Foreground" Value="#1E1E2E"/>
                </Trigger>
                <Trigger Property="Tag" Value="ActiveTerm">
                    <Setter Property="Background" Value="#4EC9B0"/>
                    <Setter Property="Foreground" Value="#1E1E2E"/>
                </Trigger>
                <Trigger Property="Tag" Value="ActiveAnalysis">
                    <Setter Property="Background" Value="#7C3AED"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconToolbarButton" TargetType="{x:Type Button}" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="Win11Thumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="#80FFFFFF" CornerRadius="2" SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Win11VerticalScrollBar" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="4"/>
            <Setter Property="MinWidth" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"><RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template></RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb><Thumb Style="{StaticResource Win11Thumb}"/></Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"><RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template></RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="1"/></Trigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type ScrollViewer}}}" Value="True"><Setter Property="Opacity" Value="1"/></DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="Win11ScrollViewer" TargetType="{x:Type ScrollViewer}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid>
                            <ScrollContentPresenter CanContentScroll="{TemplateBinding CanContentScroll}" Margin="{TemplateBinding Padding}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" HorizontalAlignment="Right" VerticalAlignment="Stretch" Style="{StaticResource Win11VerticalScrollBar}" Value="{TemplateBinding VerticalOffset}" Maximum="{TemplateBinding ScrollableHeight}" ViewportSize="{TemplateBinding ViewportHeight}" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" Margin="0,0,1,0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="LoadingDotsStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LoadingDotOne" Storyboard.TargetProperty="Opacity" From="0.3" To="1" Duration="0:0:0.4" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="LoadingDotTwo" Storyboard.TargetProperty="Opacity" From="0.3" To="1" BeginTime="0:0:0.13" Duration="0:0:0.4" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="LoadingDotThree" Storyboard.TargetProperty="Opacity" From="0.3" To="1" BeginTime="0:0:0.26" Duration="0:0:0.4" AutoReverse="True"/>
        </Storyboard>
    </Window.Resources>

    <Border Background="#E81E1E2E" CornerRadius="8" Padding="12,8" Margin="4">
        <Border.Effect><DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Grid x:Name="TitleBar" Grid.Row="0" Margin="0,0,0,6" Background="Transparent" Cursor="SizeAll">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="TranslationModeButton" Style="{StaticResource ModeButton}" Content="翻译" ToolTip="严格翻译" Click="ModeButton_Click" Tag="ActiveTranslation"/>
                    <Button x:Name="CodeModeButton" Style="{StaticResource ModeButton}" Content="命令" ToolTip="解释代码、配置或命令" Click="ModeButton_Click"/>
                    <Button x:Name="TermModeButton" Style="{StaticResource ModeButton}" Content="术语" ToolTip="解释技术术语" Click="ModeButton_Click"/>
                    <Button x:Name="AnalysisModeButton" Style="{StaticResource ModeButton}" Content="解析" ToolTip="深度解析" Click="ModeButton_Click"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource ToolbarButton}" Content="&#x21BB;" FontSize="16" ToolTip="重新生成" Click="RefreshButton_Click"/>
                    <Button Style="{StaticResource IconToolbarButton}" Content="&#x29C9;" ToolTip="复制全部" Click="CopyAllButton_Click"/>
                    <Button x:Name="PinButton" Style="{StaticResource ToolbarButton}" Content="&#x1F4CC;" FontSize="13" ToolTip="固定窗口" Click="PinButton_Click"/>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.Style>
                    <Style TargetType="{x:Type Grid}">
                        <Setter Property="MinHeight" Value="80"/>
                        <Setter Property="MaxHeight" Value="780"/>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" x:Name="TranslationScroller" Style="{StaticResource Win11ScrollViewer}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxWidth="870" ScrollChanged="TranslationScroller_ScrollChanged" PreviewMouseWheel="TranslationScroller_PreviewMouseWheel" PreviewKeyDown="TranslationScroller_PreviewKeyDown">
                    <Grid>
                        <TextBlock x:Name="TranslationTextBlock" Foreground="#F0F0F0" FontSize="16" FontFamily="Microsoft YaHei UI" TextWrapping="Wrap" Padding="0,0,6,0" Text=""/>
                        <RichTextBox x:Name="MarkdownDocumentHost" Visibility="Collapsed" IsReadOnly="True" IsDocumentEnabled="True" Focusable="False" BorderThickness="0" Background="Transparent" Padding="0" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled"/>
                    </Grid>
                </ScrollViewer>
                <Border x:Name="LoadingIndicator" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,8,0" Background="#B01E1E2E" CornerRadius="4" Padding="6,3" Visibility="Collapsed" IsHitTestVisible="False">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="LoadingDotOne" Width="4" Height="4" Fill="#B7C5FF" Margin="1"/>
                        <Ellipse x:Name="LoadingDotTwo" Width="4" Height="4" Fill="#B7C5FF" Margin="1"/>
                        <Ellipse x:Name="LoadingDotThree" Width="4" Height="4" Fill="#B7C5FF" Margin="1"/>
                    </StackPanel>
                </Border>
                <Button x:Name="ResumeScrollButton" Grid.Row="1" HorizontalAlignment="Right" Margin="0,4,0,0" Padding="6,2" FontSize="10" Style="{StaticResource ToolbarButton}" Background="#3E4B70" Content="自动滚动已暂停" ToolTip="恢复自动滚动" Visibility="Collapsed" Click="ResumeScrollButton_Click"/>
                <Button x:Name="ExpandMarkdownButton" Grid.Row="2" HorizontalAlignment="Right" Margin="0,4,0,0" Padding="6,2" FontSize="10" Style="{StaticResource ToolbarButton}" Background="#3E4B70" Content="展开全文" ToolTip="渲染完整结果" Visibility="Collapsed" Click="ExpandMarkdownButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
